pipeline {
    agent any

    environment {
        PATH = "/usr/bin:/usr/local/bin:/usr/libexec/docker/cli-plugins:$PATH"
    }

    stages {

        stage('Check Docker') {
            steps {
                sh '''
                which docker
                docker --version
                docker compose version
                '''
            }
        }

        stage('Stop Old Containers') {
            steps {
                dir('registration-app') {
                    sh '''
                    /usr/bin/docker compose down || true
                    '''
                }
            }
        }

        stage('Pull Image') {
            steps {
                sh '''
                /usr/bin/docker pull balachandru1/registration-app:latest
                '''
            }
        }

        stage('Start Containers') {
            steps {
                dir('registration-app') {
                    sh '''
                    /usr/bin/docker compose up -d
                    '''
                }
            }
        }

        stage('Verify') {
            steps {
                sh '''
                /usr/bin/docker ps
                '''
            }
        }
    }

    post {
        success {
            echo "✅ Deployment successful"
        }
        failure {
            echo "❌ Deployment failed"
        }
    }
}
