pipeline {
    agent { label 'linux' }

    environment {
        DOCKER_CONFIG = '/home/ec2-user/.docker'
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/Balachandru-ai/user-maven.git'
            }
        }

        stage('Show Files') {
            steps {
                sh '''
                pwd
                ls -la
                ls -la registration-app
                '''
            }
        }

        stage('Stop Old Containers') {
            steps {
                dir('registration-app') {
                    sh 'docker compose down || true'
                }
            }
        }

        stage('Pull Latest Image') {
            steps {
                sh 'docker pull balachandru1/registration-app:latest'
            }
        }

        stage('Start Containers') {
            steps {
                dir('registration-app') {
                    sh 'docker compose up -d'
                }
            }
        }

        stage('Verify Running Containers') {
            steps {
                sh '''
                docker ps
                '''
            }
        }
    }

    post {
        success {
            echo '✅ Deployment completed successfully'
        }
        failure {
            echo '❌ Deployment failed'
        }
    }
}
